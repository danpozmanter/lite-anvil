<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop">
  <id>io.lite_anvil.LiteAnvil</id>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>Lite Anvil</name>
  <summary>A lightweight text editor written in Lua with a Rust core</summary>
  <content_rating type="oars-1.0" />
  <launchable type="desktop-id">com.lite_anvil.LiteAnvil.desktop</launchable>

  <description>
    <p>
      Lite Anvil is a text editor and development tool written mainly in Lua,
      on top of a Rust core using the SDL2 graphics library.
    </p>
  </description>

  <provides>
    <binary>lite-anvil</binary>
  </provides>

  @METAINFO_RELEASES@
</component>
